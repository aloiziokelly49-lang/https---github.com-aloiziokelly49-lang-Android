<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="com.cloudink.app.ui.editor.HandwriteEditorViewModel" />
        <variable
            name="voice"
            type="com.cloudink.app.ui.editor.EditorVoiceState" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/background"
        tools:context=".ui.editor.HandwriteEditorActivity">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="手写模拟器"
            app:titleTextColor="@color/on_primary"
            app:navigationIcon="?attr/homeAsUpIndicator" />

        <!-- 上半部分: 预览画布 -->
        <FrameLayout
            android:id="@+id/preview_frame"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#F0EDE4">

            <com.cloudink.app.rendering.PreviewCanvas
                android:id="@+id/preview_canvas"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:renderedBitmap="@{viewModel.renderedBitmap}" />

            <include
                android:id="@+id/audio_panel"
                layout="@layout/layout_editor_audio_panel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:editorVm="@{viewModel}"
                app:voice="@{voice}" />

        </FrameLayout>

        <!-- 分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/primary_container" />

        <!-- 下半部分: 控制面板 (可滚动) -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="24dp">

                <!-- === 文本输入 === -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="1dp"
                    app:cardCornerRadius="8dp"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="输入排版文本"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:padding="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_input_text"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:gravity="top|start"
                            android:inputType="textMultiLine|textCapSentences"
                            android:scrollbars="vertical"
                            android:overScrollMode="always"
                            android:maxLines="12"
                            android:minLines="8"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4dp"
                            android:text="@={viewModel.inputText}" />

                    </com.google.android.material.textfield.TextInputLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- === 抖动 === -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:text="手写抖动"
                    android:paddingStart="4dp"
                    android:layout_marginTop="8dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <SeekBar
                        android:id="@+id/slider_jitter"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="100" />
                    <TextView
                        android:id="@+id/tv_jitter_val"
                        android:layout_width="50dp"
                        android:layout_height="wrap_content"
                        android:textAlignment="center"
                        android:textSize="13sp"
                        android:textColor="@color/secondary" />
                </LinearLayout>

                <!-- === 字距 === -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:text="字距"
                    android:paddingStart="4dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <SeekBar
                        android:id="@+id/slider_char_spacing"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="100" />
                    <TextView
                        android:id="@+id/tv_char_spacing_val"
                        android:layout_width="50dp"
                        android:layout_height="wrap_content"
                        android:textAlignment="center"
                        android:textSize="13sp"
                        android:textColor="@color/secondary" />
                </LinearLayout>

                <!-- === 行距 === -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:text="行距"
                    android:paddingStart="4dp"
                    android:layout_marginTop="8dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <SeekBar
                        android:id="@+id/slider_line_spacing"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="100" />
                    <TextView
                        android:id="@+id/tv_line_spacing_val"
                        android:layout_width="50dp"
                        android:layout_height="wrap_content"
                        android:textAlignment="center"
                        android:textSize="13sp"
                        android:textColor="@color/secondary" />
                </LinearLayout>

                <!-- === 纸张配色主题 === -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:text="纸张配色"
                    android:paddingStart="4dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="4dp" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggle_theme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:checkedButton="@+id/btn_theme_eye_care">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_theme_eye_care"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="护眼黄"
                        android:textSize="10sp"
                        app:cornerRadius="0dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_theme_white"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="极简白"
                        android:textSize="10sp"
                        app:cornerRadius="0dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_theme_dark"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="深邃黑"
                        android:textSize="10sp"
                        app:cornerRadius="0dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_theme_gray"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="简约灰"
                        android:textSize="10sp"
                        app:cornerRadius="0dp" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

                <!-- === 纸张背景 === -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:text="纸张背景"
                    android:paddingStart="4dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="4dp" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggle_paper"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:checkedButton="@+id/btn_paper_0">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_paper_0"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="纯白"
                        android:textSize="11sp"
                        app:cornerRadius="0dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_paper_1"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="横线"
                        android:textSize="11sp"
                        app:cornerRadius="0dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_paper_2"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="方格"
                        android:textSize="11sp"
                        app:cornerRadius="0dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_paper_3"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="点阵"
                        android:textSize="11sp"
                        app:cornerRadius="0dp" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

                <!-- === 笔触 === -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:text="笔触类型"
                    android:paddingStart="4dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="4dp" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggle_pen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:checkedButton="@+id/btn_pen_fountain">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_pen_fountain"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="钢笔"
                        android:textSize="11sp"
                        app:cornerRadius="0dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_pen_ballpoint"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="圆珠笔"
                        android:textSize="11sp"
                        app:cornerRadius="0dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_pen_marker"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="马克笔"
                        android:textSize="11sp"
                        app:cornerRadius="0dp" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

                <!-- === 手写字体 === -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:text="手写字体"
                    android:paddingStart="4dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="4dp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:fillViewport="false">

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggle_font"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true" />

                </HorizontalScrollView>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>
</layout>
