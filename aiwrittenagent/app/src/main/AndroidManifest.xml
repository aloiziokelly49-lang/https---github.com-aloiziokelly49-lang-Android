<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Camera -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Audio recording -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- Storage (pre-Android 10 only) -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- 可选：OCR 语言包已内置 assets，无需联网 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Required hardware features -->
    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <uses-feature android:name="android.hardware.microphone" android:required="true" />

    <application
        android:name=".CloudInkApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.CloudInk"
        android:requestLegacyExternalStorage="true"
        android:usesCleartextTraffic="false">

        <!-- Splash / Login -->
        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.CloudInk">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main Home -->
        <activity
            android:name=".ui.home.HomeActivity"
            android:exported="false"
            android:theme="@style/Theme.CloudInk" />

        <!-- Settings / Profile -->
        <activity
            android:name=".ui.profile.ProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.CloudInk" />

        <!-- 文档纵向浏览 (PdfRenderer + RecyclerView) -->
        <activity
            android:name=".ui.document.DocumentViewerActivity"
            android:exported="false"
            android:theme="@style/Theme.CloudInk"
            android:configChanges="orientation|screenSize" />

        <!-- Camera OCR -->
        <activity
            android:name=".ui.ocr.CameraOcrActivity"
            android:exported="false"
            android:theme="@style/Theme.CloudInk" />



        <!-- Voice transcribe library -->
        <activity
            android:name=".ui.asr.VoiceTranscribeActivity"
            android:exported="false"
            android:theme="@style/Theme.CloudInk" />

        <!-- Handwrite Editor -->
        <activity
            android:name=".ui.editor.HandwriteEditorActivity"
            android:exported="false"
            android:theme="@style/Theme.CloudInk"
            android:configChanges="orientation|screenSize" />

        <!-- Export Preview -->
        <activity
            android:name=".ui.export.ExportPreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.CloudInk"
            tools:targetApi="29" />

        <!-- History Archive -->
        <activity
            android:name=".ui.history.HistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.CloudInk" />

        <!-- Audio Recording Service -->
        <service
            android:name=".asr.AudioRecorderService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

    </application>

</manifest>
